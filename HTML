          <div><div style={{fontSize:11,color:C.textMuted,marginBottom:3}}>類別</div><select value={nPack.cat} onChange={e=>setNPack(p=>({...p,cat:e.target.value}))} style={inp}>{Object.keys(CI).map(c=><option key={c}>{c}</option>)}</select></div>
