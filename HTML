                <button onClick={()=>rmExp(exp.id)} style={{background:'none',border:'none',color:'#ccc',fontSize:18,cursor:'pointer',flexShrink:0,lineHeight:1}}>×</button>
              </div>
            </div>
          );
        })}
      </div>
