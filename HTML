    const L=window.L;
    if(mref.current){mref.current.remove();mref.current=null;}
    const map=L.map(ref.current,{zoomControl:true,scrollWheelZoom:false});
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OSM',maxZoom:18}).addTo(map);
    const lls=spots.map((a,i)=>{
      const t=AT[a.type]||AT.sight;
      const icon=L.divIcon({html:`<div style="background:${t.color};color:#fff;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.25)">${i+1}</div>`,className:'',iconSize:[26,26],iconAnchor:[13,13],popupAnchor:[0,-14]});
      L.marker(a.coords,{icon}).addTo(map).bindPopup(`<b>${a.time}</b><br/>${a.name}`);
      return a.coords;
    });
    if(lls.length>1)L.polyline(lls,{color:C.primary,weight:2.5,opacity:.65,dashArray:'6,5'}).addTo(map);
    map.fitBounds(L.latLngBounds(lls),{padding:[22,22]});
    mref.current=map;
    return()=>{if(mref.current){mref.current.remove();mref.current=null;}};
  },[lReady,JSON.stringify(spots.map(s=>s.id))]);
  if(!spots.length)return <div style={{padding:14,textAlign:'center',color:C.textMuted,fontSize:12,background:C.veryLight,borderRadius:10,marginTop:10}}>尚無含座標的行程</div>;
  return <div ref={ref} style={{height:240,borderRadius:10,overflow:'hidden',marginTop:10,border:`1px solid ${C.borderLight}`}}/>;
}

