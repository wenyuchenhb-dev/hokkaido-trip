      display:flex;flex-direction:column;align-items:center;justify-content:center;
      z-index:9999;transition:opacity .5s ease}
    #splash.out{opacity:0;pointer-events:none}
    .si{font-size:72px;margin-bottom:20px;animation:pulse 1.5s ease-in-out infinite}
    .st{color:#fff;font-size:22px;font-weight:700;letter-spacing:.15em;margin-bottom:6px;
