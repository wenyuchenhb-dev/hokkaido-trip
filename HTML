async function compressPhoto(file){
  return new Promise(resolve=>{
    const r=new FileReader();
    r.onload=e=>{const img=new Image();img.onload=()=>{const MAX=480;let w=img.width,h=img.height;if(w>h){if(w>MAX){h=Math.round(h*(MAX/w));w=MAX;}}else{if(h>MAX){w=Math.round(w*(MAX/h));h=MAX;}}const c=document.createElement('canvas');c.width=w;c.height=h;c.getContext('2d').drawImage(img,0,0,w,h);resolve(c.toDataURL('image/jpeg',.65));};img.src=e.target.result;};r.readAsDataURL(file);
  });
}

